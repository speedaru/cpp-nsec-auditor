@Library('nsec-pipeline-library@v1') _

pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Checkout the project code
                checkout scm
                
                // Checkout the auditor tool into a specific folder
                dir('nsec-auditor') {
                    git url: 'https://github.com/natixis-security/nsec-auditor.git', branch: 'main'
                }
            }
        }

        stage('Security Audit') {
            steps {
                // Call the global step with surgical precision
                nsecAudit(
                    scanPath: 'src/cpp-backend',
                    toolDir: 'nsec-auditor',
                    failOnError: true
                )
            }
        }
    }
}
